<script>
// ── Scroll-based reveal
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); } });
}, { threshold: 0.07, rootMargin: '0px 0px -50px 0px' });
document.querySelectorAll('.sr,.sr-l,.sr-r,.sr-sc,.zoom-reveal').forEach(el => io.observe(el));

// ── Nav blur
window.addEventListener('scroll', () => {
  document.getElementById('mainNav').style.background =
    window.scrollY > 40 ? 'rgba(0,0,0,0.92)' : 'rgba(0,0,0,0.75)';
}, { passive: true });

// ── Scroll-zoom for szoom sections (scale bg on scroll)
const szSections = document.querySelectorAll('[data-szoom]');
function onScroll() {
  szSections.forEach(sec => {
    const bg = sec.querySelector('[data-parallax]');
    if (!bg) return;
    const rect = sec.getBoundingClientRect();
    const wh = window.innerHeight;
    // progress: 0 when top hits bottom of viewport, 1 when bottom hits top
    const progress = 1 - Math.min(Math.max(rect.bottom / (wh + rect.height), 0), 1);
    // Scale from 1.08 → 1.0 as section scrolls into view, then parallax offset
    const scale = 1.1 - progress * 0.08;
    const translateY = (progress - 0.5) * 60; // parallax
    bg.style.transform = `scale(${scale}) translateY(${translateY}px)`;
  });

  // Hero bg subtle zoom-out as user scrolls down
  const heroBg = document.getElementById('heroBg');
  if (heroBg) {
    const sy = window.scrollY;
    const scale = Math.max(1.0, 1.0 + sy * 0.0002);
    const opa  = Math.max(0, 1 - sy * 0.001);
    heroBg.style.transform = `scale(${scale})`;
    heroBg.style.opacity   = opa;
  }
}
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ── FAQ
function tFaq(el) {
  const item = el.parentElement;
  const open = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
  if (!open) item.classList.add('open');
}
</script>
