<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cloudeva.ai — AI-First Multi-Cloud Decision Governance</title>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --accent:#0071e3;
  --accent-light:#2997ff;
  --cyan:#00c8ff;
  --green:#34c759;
  --grey-100:#f5f5f7;
  --grey-600:#6e6e73;
  --grey-800:#1d1d1f;
}
html{scroll-behavior:smooth;font-size:16px;}
body{font-family:'Figtree',-apple-system,sans-serif;background:#000;color:#fff;overflow-x:hidden;-webkit-font-smoothing:antialiased;}

/* ═══════════════ NAV ═══════════════ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  height:52px;display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;
  background:rgba(0,0,0,0.75);
  backdrop-filter:saturate(180%) blur(20px);
  -webkit-backdrop-filter:saturate(180%) blur(20px);
  border-bottom:0.5px solid rgba(255,255,255,0.1);
  transition:background 0.4s;
}
.nav-logo svg{height:30px;width:auto;}
.nav-links{display:flex;gap:28px;list-style:none;position:absolute;left:50%;transform:translateX(-50%);}
.nav-links a{font-size:0.75rem;color:rgba(255,255,255,0.75);text-decoration:none;letter-spacing:0.01em;transition:color 0.2s;}
.nav-links a:hover{color:#fff;}
.nav-actions{display:flex;gap:16px;align-items:center;}
.nav-actions a{font-size:0.75rem;color:var(--accent-light);text-decoration:none;transition:opacity 0.2s;}
.nav-pill{background:var(--accent);color:#fff !important;padding:6px 16px;border-radius:980px;font-size:0.75rem;font-weight:600;text-decoration:none;transition:background 0.2s;}
.nav-pill:hover{background:#0077ed;}

/* ═══════════════ HERO — full-bleed image + zoom ═══════════════ */
.hero{
  position:relative;min-height:100vh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:120px 24px 80px;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;z-index:0;
  background:
    linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.3) 40%, rgba(0,0,0,0.7) 100%),
    url('https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1800&auto=format&fit=crop&q=80') center/cover no-repeat;
  transform:scale(1.12);
  animation:heroBgZoom 1.6s cubic-bezier(0.16,1,0.3,1) forwards;
  will-change:transform;
}
@keyframes heroBgZoom{from{transform:scale(1.25);}to{transform:scale(1.0);}}

/* Mesh overlay */
.hero-mesh{
  position:absolute;inset:0;z-index:1;
  background-image:linear-gradient(rgba(0,113,227,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,113,227,0.04) 1px,transparent 1px);
  background-size:70px 70px;
  animation:meshDrift 50s linear infinite;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%);
}
@keyframes meshDrift{0%{transform:translate(0,0);}100%{transform:translate(70px,70px);}}

.hero-content{position:relative;z-index:2;}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  font-size:0.78rem;font-weight:600;color:var(--accent-light);
  letter-spacing:0.06em;text-transform:uppercase;margin-bottom:24px;
  opacity:0;animation:riseIn 0.9s 0.3s cubic-bezier(0.16,1,0.3,1) forwards;
}
.hero-eyebrow::before{content:'';width:7px;height:7px;background:var(--green);border-radius:50%;box-shadow:0 0 10px var(--green);animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}

.hero h1{
  font-size:clamp(3rem,8vw,7.5rem);font-weight:900;
  line-height:1.0;letter-spacing:-0.045em;color:#fff;
  max-width:1100px;
  opacity:0;animation:riseIn 1s 0.5s cubic-bezier(0.16,1,0.3,1) forwards;
  text-shadow:0 4px 40px rgba(0,0,0,0.5);
}
.hero h1 em{
  font-style:normal;
  background:linear-gradient(135deg,#fff 0%,rgba(0,200,255,0.95) 50%,#2997ff 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-sub{
  margin-top:22px;font-size:clamp(1rem,2vw,1.3rem);font-weight:400;
  color:rgba(255,255,255,0.6);max-width:620px;line-height:1.65;letter-spacing:-0.01em;
  opacity:0;animation:riseIn 1s 0.7s cubic-bezier(0.16,1,0.3,1) forwards;
}
.hero-actions{
  display:flex;gap:16px;margin-top:40px;flex-wrap:wrap;justify-content:center;
  opacity:0;animation:riseIn 1s 0.9s cubic-bezier(0.16,1,0.3,1) forwards;
}
.btn-apple{display:inline-flex;align-items:center;gap:6px;padding:14px 30px;border-radius:980px;font-size:0.95rem;font-weight:700;font-family:'Figtree',sans-serif;text-decoration:none;letter-spacing:-0.01em;cursor:pointer;border:none;transition:all 0.3s cubic-bezier(0.16,1,0.3,1);}
.btn-blue{background:var(--accent);color:#fff;}
.btn-blue:hover{background:#0077ed;transform:scale(1.03);box-shadow:0 0 40px rgba(0,113,227,0.4);}
.btn-ghost{background:rgba(255,255,255,0.12);color:#fff;border:0.5px solid rgba(255,255,255,0.18);backdrop-filter:blur(10px);}
.btn-ghost:hover{background:rgba(255,255,255,0.2);transform:scale(1.03);}

.cloud-strip{
  display:flex;align-items:center;gap:14px;margin-top:56px;flex-wrap:wrap;justify-content:center;
  opacity:0;animation:riseIn 1s 1.1s cubic-bezier(0.16,1,0.3,1) forwards;
}
.cloud-pill{display:flex;align-items:center;gap:8px;padding:7px 16px;border-radius:980px;background:rgba(255,255,255,0.07);border:0.5px solid rgba(255,255,255,0.12);font-size:0.75rem;color:rgba(255,255,255,0.65);font-weight:500;backdrop-filter:blur(10px);}
.cp-dot{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:0.55rem;font-weight:900;}
.cp-aws{background:#FF9900;color:#000;}.cp-az{background:#0078D4;color:#fff;}.cp-gcp{background:#4285F4;color:#fff;}
.strip-sep{width:1px;height:24px;background:rgba(255,255,255,0.1);}

/* Dashboard mockup */
.hero-visual{
  position:relative;z-index:2;margin-top:72px;width:100%;max-width:1060px;
  opacity:0;animation:riseIn 1.2s 1.3s cubic-bezier(0.16,1,0.3,1) forwards;
}
.dash-frame{border-radius:18px;border:0.5px solid rgba(255,255,255,0.12);overflow:hidden;background:rgba(12,12,16,0.92);box-shadow:0 60px 140px rgba(0,0,0,0.8),0 0 80px rgba(0,113,227,0.12);backdrop-filter:blur(20px);}
.dash-titlebar{background:rgba(30,30,34,0.9);padding:12px 16px;display:flex;align-items:center;gap:8px;border-bottom:0.5px solid rgba(255,255,255,0.06);}
.tb-dot{width:12px;height:12px;border-radius:50%;}
.tb-r{background:#ff5f57;}.tb-y{background:#ffbd2e;}.tb-g{background:#28ca41;}
.tb-addr{margin:0 auto;background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.07);border-radius:6px;padding:4px 80px;font-size:0.68rem;color:rgba(255,255,255,0.25);}
.dash-body{display:grid;grid-template-columns:190px 1fr;min-height:320px;}
.dash-sidebar{background:rgba(8,8,12,0.9);border-right:0.5px solid rgba(255,255,255,0.05);padding:16px 0;}
.side-logo{padding:0 14px 16px;border-bottom:0.5px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:8px;font-size:0.78rem;font-weight:700;color:#fff;}
.side-logo-mark{width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,#0071e3,#00c8ff);display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:900;color:#fff;}
.side-item{padding:7px 14px;font-size:0.7rem;color:rgba(255,255,255,0.35);display:flex;align-items:center;gap:7px;border-radius:6px;margin:2px 8px;transition:all 0.2s;}
.side-item.active{background:rgba(0,113,227,0.15);color:var(--accent-light);}
.dash-main{padding:18px;display:flex;flex-direction:column;gap:14px;}
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.kpi{background:rgba(255,255,255,0.03);border:0.5px solid rgba(255,255,255,0.06);border-radius:10px;padding:12px;}
.kpi-label{font-size:0.62rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:5px;}
.kpi-val{font-size:1.35rem;font-weight:800;letter-spacing:-0.03em;}
.kpi-ch{font-size:0.6rem;margin-top:3px;}
.c-cyan{color:var(--cyan);}.c-green{color:var(--green);}.c-yellow{color:#ffd60a;}.c-red{color:#ff453a;}
.dash-row2{display:grid;grid-template-columns:1fr 190px;gap:12px;flex:1;}
.chart-card{background:rgba(255,255,255,0.03);border:0.5px solid rgba(255,255,255,0.06);border-radius:10px;padding:14px;position:relative;overflow:hidden;}
.chart-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.chart-title{font-size:0.7rem;font-weight:600;color:rgba(255,255,255,0.6);}
.chart-badge{font-size:0.58rem;background:rgba(0,200,255,0.1);border:0.5px solid rgba(0,200,255,0.3);color:var(--cyan);padding:2px 8px;border-radius:20px;}
.chart-svg{width:100%;height:75px;}
.ev-card{background:rgba(255,255,255,0.03);border:0.5px solid rgba(255,255,255,0.06);border-radius:10px;padding:14px;}
.ev-title{font-size:0.7rem;font-weight:600;color:rgba(255,255,255,0.6);margin-bottom:10px;}
.ev-item{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:0.5px solid rgba(255,255,255,0.04);font-size:0.63rem;color:rgba(255,255,255,0.4);}
.ev-item:last-child{border:none;}
.ev-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}

/* ═══════════════ TICKER ═══════════════ */
.ticker-wrap{background:#000;border-top:0.5px solid rgba(255,255,255,0.07);border-bottom:0.5px solid rgba(255,255,255,0.07);overflow:hidden;padding:16px 0;position:relative;}
.ticker-wrap::before{content:'';position:absolute;left:0;top:0;bottom:0;width:100px;background:linear-gradient(90deg,#000,transparent);z-index:2;}
.ticker-wrap::after{content:'';position:absolute;right:0;top:0;bottom:0;width:100px;background:linear-gradient(-90deg,#000,transparent);z-index:2;}
.ticker-track{display:flex;white-space:nowrap;animation:tickerScroll 22s linear infinite;}
.ticker-item{display:inline-flex;align-items:center;gap:12px;padding:0 52px;font-size:0.8rem;color:rgba(255,255,255,0.3);}
.ticker-val{font-weight:800;color:#fff;font-size:0.86rem;}
.ticker-sep{color:rgba(255,255,255,0.1);}
@keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ═══════════════ SCROLL-ZOOM IMAGE SECTIONS ═══════════════ */
/* Each .szoom-section has a parallax + zoom bg image driven by JS */
.szoom-section{
  position:relative;overflow:hidden;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:140px 24px;min-height:90vh;
}
.szoom-bg{
  position:absolute;inset:-60px;z-index:0;
  background-size:cover;background-position:center;background-attachment:fixed;
  will-change:transform;transition:none;
}
/* Dark overlay per section */
.szoom-overlay{position:absolute;inset:0;z-index:1;}
.szoom-content{position:relative;z-index:2;max-width:900px;margin:0 auto;}

/* Section 1 — Data Center */
.sz-datacenter .szoom-bg{
  background-image:
    linear-gradient(to bottom,rgba(0,0,0,0.65) 0%,rgba(0,5,20,0.5) 50%,rgba(0,0,0,0.75) 100%),
    url('https://images.unsplash.com/photo-1544197150-b99a580bb7a8?w=1800&auto=format&fit=crop&q=80');
}
/* Section 2 — Abstract Network */
.sz-network .szoom-bg{
  background-image:
    linear-gradient(to bottom,rgba(0,0,0,0.7) 0%,rgba(0,8,30,0.55) 50%,rgba(0,0,0,0.75) 100%),
    url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1800&auto=format&fit=crop&q=80');
}
/* Section 3 — Server Racks */
.sz-servers .szoom-bg{
  background-image:
    linear-gradient(to bottom,rgba(0,0,0,0.7) 0%,rgba(0,0,0,0.45) 50%,rgba(0,0,0,0.8) 100%),
    url('https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=1800&auto=format&fit=crop&q=80');
}
/* Section 4 — City Lights / Cloud */
.sz-city .szoom-bg{
  background-image:
    linear-gradient(to bottom,rgba(0,0,0,0.72) 0%,rgba(0,5,25,0.5) 50%,rgba(0,0,0,0.8) 100%),
    url('https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=1800&auto=format&fit=crop&q=80');
}
/* Section 5 — AI / Futuristic */
.sz-ai .szoom-bg{
  background-image:
    linear-gradient(to bottom,rgba(0,0,0,0.65) 0%,rgba(0,8,30,0.5) 50%,rgba(0,0,0,0.8) 100%),
    url('https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=1800&auto=format&fit=crop&q=80');
}

/* Typography inside szoom */
.sz-eyebrow{font-size:0.78rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:16px;}
.sz-eyebrow-blue{color:var(--accent-light);}
.sz-eyebrow-cyan{color:var(--cyan);}
.sz-eyebrow-green{color:var(--green);}
.sz-h2{font-size:clamp(2.5rem,6vw,5.5rem);font-weight:900;letter-spacing:-0.045em;line-height:1.0;color:#fff;margin-bottom:20px;text-shadow:0 4px 40px rgba(0,0,0,0.5);}
.sz-h2 em{font-style:normal;background:linear-gradient(135deg,#fff,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sz-body{font-size:clamp(1rem,1.8vw,1.2rem);color:rgba(255,255,255,0.55);max-width:620px;margin:0 auto 40px;line-height:1.7;letter-spacing:-0.01em;}

/* ═══════════════ FEATURE GRID (dark, no bg) ═══════════════ */
.feat-section{background:#000;padding:0 24px 100px;}
.feat-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:2px;border-radius:22px;overflow:hidden;border:0.5px solid rgba(255,255,255,0.07);}
.feat-cell{background:#0a0a0d;padding:48px 38px;position:relative;overflow:hidden;transition:background 0.4s;}
.feat-cell::before{content:'';position:absolute;top:0;left:0;right:0;height:1.5px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:0;transition:opacity 0.4s;}
.feat-cell:hover::before{opacity:1;}
.feat-cell:hover{background:#111115;}
.fi{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:1.4rem;}
.fi-b{background:rgba(0,113,227,0.15);box-shadow:inset 0 0 0 0.5px rgba(0,113,227,0.3);}
.fi-c{background:rgba(0,200,255,0.1);box-shadow:inset 0 0 0 0.5px rgba(0,200,255,0.25);}
.fi-g{background:rgba(52,199,89,0.1);box-shadow:inset 0 0 0 0.5px rgba(52,199,89,0.25);}
.feat-cell h3{font-size:1.05rem;font-weight:700;letter-spacing:-0.025em;color:#fff;margin-bottom:10px;}
.feat-cell p{font-size:0.86rem;color:rgba(255,255,255,0.4);line-height:1.65;}

/* ═══════════════ EVA SECTION ═══════════════ */
.eva-section{background:#000;padding:0 24px;border-top:0.5px solid rgba(255,255,255,0.07);}
.eva-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;padding:120px 0;}
.eva-copy .eyebrow{font-size:0.78rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:14px;}
.eva-copy h2{font-size:clamp(2rem,4vw,3.6rem);font-weight:900;letter-spacing:-0.04em;line-height:1.05;color:#fff;margin-bottom:20px;}
.eva-copy p{font-size:0.98rem;color:rgba(255,255,255,0.45);line-height:1.7;margin-bottom:14px;}
.eva-model{display:flex;border:0.5px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;margin-top:28px;}
.eva-step{flex:1;padding:16px 10px;text-align:center;border-right:0.5px solid rgba(255,255,255,0.07);transition:background 0.3s;}
.eva-step:last-child{border:none;}
.eva-step:hover{background:rgba(255,255,255,0.04);}
.eva-step-letter{font-size:1.5rem;font-weight:900;color:var(--accent-light);margin-bottom:4px;}
.eva-step-word{font-size:0.65rem;color:rgba(255,255,255,0.3);letter-spacing:0.05em;text-transform:uppercase;}
.eva-vis{display:flex;justify-content:center;align-items:center;position:relative;}
.eva-sphere{width:360px;height:360px;border-radius:50%;position:relative;display:flex;align-items:center;justify-content:center;}
.eva-sphere-bg{position:absolute;inset:0;border-radius:50%;background:radial-gradient(circle at 35% 35%,#0a1f40 0%,#000510 60%,#000 100%);border:0.5px solid rgba(0,113,227,0.22);animation:sphereGlow 5s ease-in-out infinite;}
@keyframes sphereGlow{0%,100%{box-shadow:0 0 60px rgba(0,113,227,0.18),inset 0 0 40px rgba(0,113,227,0.05);}50%{box-shadow:0 0 100px rgba(0,200,255,0.22),inset 0 0 60px rgba(0,200,255,0.07);}}
.eva-ring{position:absolute;border-radius:50%;border:0.5px solid rgba(0,113,227,0.12);animation:ringPulse 3s ease-in-out infinite;}
.eva-ring-1{inset:-22px;animation-delay:0s;}
.eva-ring-2{inset:-44px;animation-delay:1s;}
.eva-ring-3{inset:-66px;animation-delay:2s;}
@keyframes ringPulse{0%,100%{opacity:0.9;transform:scale(1);}50%{opacity:0.3;transform:scale(1.04);}}
.eva-label{position:relative;z-index:1;text-align:center;}
.eva-label-main{font-size:4.5rem;font-weight:900;letter-spacing:-0.06em;background:linear-gradient(135deg,#fff 30%,var(--cyan) 70%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.eva-label-sub{font-size:0.72rem;color:rgba(255,255,255,0.3);letter-spacing:0.12em;text-transform:uppercase;}
.eva-float{position:absolute;right:-24px;top:32px;background:rgba(8,18,38,0.92);border:0.5px solid rgba(0,113,227,0.3);border-radius:14px;padding:14px 18px;font-size:0.7rem;color:rgba(255,255,255,0.6);max-width:195px;backdrop-filter:blur(20px);animation:cardFloat 4s ease-in-out infinite;box-shadow:0 24px 60px rgba(0,0,0,0.6);}
@keyframes cardFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
.fc-hdr{color:var(--cyan);font-weight:700;font-size:0.68rem;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.fc-live{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:blink 2s infinite;}
.fc-row{display:flex;justify-content:space-between;margin-top:5px;}
.fc-k{color:rgba(255,255,255,0.3);}
.fc-v{color:#fff;font-weight:700;}

/* ═══════════════ METRICS ═══════════════ */
.metrics-section{background:#000;border-top:0.5px solid rgba(255,255,255,0.07);padding:0 24px;}
.metrics-inner{max-width:1200px;margin:0 auto;padding:100px 0;text-align:center;}
.section-eyebrow{font-size:0.78rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:14px;}
.section-headline{font-size:clamp(2.2rem,5vw,4.2rem);font-weight:900;letter-spacing:-0.045em;line-height:1.05;margin-bottom:0;}
.section-sub{font-size:1rem;color:rgba(255,255,255,0.4);max-width:540px;margin:16px auto 0;line-height:1.65;}
.metrics-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:60px;border-radius:20px;overflow:hidden;border:0.5px solid rgba(255,255,255,0.07);}
.metric-tile{background:#0a0a0d;padding:56px 32px;text-align:center;transition:background 0.3s;}
.metric-tile:hover{background:#111;}
.metric-big{font-size:clamp(3.2rem,5vw,5.2rem);font-weight:900;letter-spacing:-0.055em;line-height:1;margin-bottom:10px;}
.metric-tile p{font-size:0.86rem;color:rgba(255,255,255,0.35);line-height:1.5;max-width:200px;margin:0 auto;}

/* ═══════════════ INDUSTRIES (light section) ═══════════════ */
.industries-section{background:var(--grey-100);padding:120px 24px;color:var(--grey-800);}
.industries-inner{max-width:1200px;margin:0 auto;}
.ind-head{text-align:center;margin-bottom:64px;}
